direction: down

title: |md
  # Helixir-rs — Components
| {near: top-center; shape: text}

mcp: "MCP Layer  v2.0.0" {
  style.fill: "#DBEAFE"
  style.stroke: "#3B82F6"
  style.border-radius: 10

  server: "HelixirMcpServer\n14 tools · 2 prompts · 2 resources" {
    style.fill: "#1D4ED8"; style.font-color: white; style.border-radius: 6
  }
  params: Typed Params {style.fill: "#3B82F6"; style.font-color: white; style.border-radius: 6}
  prompts: "Cognitive Protocol\nMemory Summary" {style.fill: "#3B82F6"; style.font-color: white; style.border-radius: 6}
}

core: Core {
  style.fill: "#FFF7ED"
  style.stroke: "#F97316"
  style.border-radius: 10

  client: "HelixirClient\n(facade)" {style.fill: "#EA580C"; style.font-color: white; style.border-radius: 6}
  config: "Config\nSearchThresholds\nmax_facts_per_call" {style.fill: "#FB923C"; style.font-color: white; style.border-radius: 6}
  events: "EventBus\n6 event types" {
    style.fill: "#FEF9C3"; style.stroke: "#EAB308"; style.border-radius: 6
    style.double-border: true
  }
  modes: "Search Modes\nrecent · contextual\ndeep · full" {style.fill: "#FB923C"; style.font-color: white; style.border-radius: 6}
}

tooling: ToolingManager {
  style.fill: "#DCFCE7"
  style.stroke: "#22C55E"
  style.border-radius: 10

  pipeline: "Add Pipeline\n2-phase dedup\nbatch embed" {style.fill: "#166534"; style.font-color: white; style.border-radius: 6}
  search_mgr: "Search Router\nscope dispatch" {style.fill: "#166534"; style.font-color: white; style.border-radius: 6}
  helpers: "Graph Helpers\n13 edge types\nsession · agent\ncontext · history" {style.fill: "#15803D"; style.font-color: white; style.border-radius: 6}
  emitters: "Event Emitters\nmemory · search · llm" {style.fill: "#22C55E"; style.font-color: white; style.border-radius: 6}
}

mind: Mind Toolbox {
  style.fill: "#F3E8FF"
  style.stroke: "#A855F7"
  style.border-radius: 10

  search: "SearchEngine\nSmartTraversalV2 · Hybrid · BM25\n+ Moka cache (TTL 60s)" {
    style.fill: "#6B21A8"; style.font-color: white; style.border-radius: 6
  }
  entity: EntityManager {style.fill: "#7E22CE"; style.font-color: white; style.border-radius: 6}
  reasoning: "ReasoningEngine\nIMPLIES · BECAUSE\nCONTRADICTS · SUPPORTS" {style.fill: "#7E22CE"; style.font-color: white; style.border-radius: 6}
  ontology: "OntologyManager\n7 concept types" {style.fill: "#7E22CE"; style.font-color: white; style.border-radius: 6}
  chunking: ChunkingManager {style.fill: "#7E22CE"; style.font-color: white; style.border-radius: 6}
  fast_think: "FastThink\nMCP 90s · 150 thoughts" {style.fill: "#7E22CE"; style.font-color: white; style.border-radius: 6}
}

llm: LLM Layer {
  style.fill: "#FFE4E6"
  style.stroke: "#F43F5E"
  style.border-radius: 10

  decision: "Decision Engine\nretry · validation · metrics" {style.fill: "#BE123C"; style.font-color: white; style.border-radius: 6}
  extractor: "Memory Extractor\natomization · entity rels" {style.fill: "#E11D48"; style.font-color: white; style.border-radius: 6}
  embeddings: "Embeddings\nbatch + fallback" {style.fill: "#E11D48"; style.font-color: white; style.border-radius: 6}
  providers: "Providers\nCerebras · OpenAI · Ollama" {style.fill: "#F43F5E"; style.font-color: white; style.border-radius: 6}
}

db: Database {
  style.fill: "#F1F5F9"
  style.stroke: "#64748B"
  style.border-radius: 10

  helix: "HelixDB Client\nHTTP → HelixDB · 117 queries" {
    shape: cylinder; style.fill: "#334155"; style.font-color: white
  }
}

# Connections
mcp.server -> core.client: API
mcp.server -> mind.fast_think: "FastThink (90s)"
core.client -> tooling.pipeline: add_memory
core.client -> tooling.search_mgr: search_memory
core.config -> tooling.pipeline: thresholds {style.stroke-dash: 3}
core.config -> llm.decision: thresholds {style.stroke-dash: 3}

tooling.pipeline -> llm.extractor: extract
tooling.pipeline -> llm.embeddings: "batch embed"
tooling.pipeline -> mind.search: "Phase 1 + 2"
tooling.pipeline -> llm.decision: decide
tooling.pipeline -> mind.ontology: concepts
tooling.pipeline -> mind.reasoning: relations
tooling.pipeline -> mind.entity: entities
tooling.pipeline -> mind.chunking: chunk
tooling.pipeline -> tooling.helpers
tooling.emitters -> core.events: emit {style.stroke-dash: 3; style.stroke: "#EAB308"}
tooling.search_mgr -> mind.search: route

mind.search -> db.helix: HQL
tooling.helpers -> db.helix: "33 edge types"
llm.decision -> llm.providers
llm.extractor -> llm.providers
llm.embeddings -> llm.providers: "embedding API"
