direction: right

title: |md
  # Helixir-rs — Data Flow
| {near: top-center; shape: text}

classes: {
  blue: {style.fill: "#DBEAFE"; style.stroke: "#3B82F6"; style.border-radius: 8}
  orange: {style.fill: "#FFF7ED"; style.stroke: "#F97316"; style.border-radius: 8}
  green: {style.fill: "#DCFCE7"; style.stroke: "#22C55E"; style.border-radius: 8}
  purple: {style.fill: "#F3E8FF"; style.stroke: "#A855F7"; style.border-radius: 8}
  rose: {style.fill: "#FFE4E6"; style.stroke: "#F43F5E"; style.border-radius: 8}
  amber: {style.fill: "#FEF9C3"; style.stroke: "#EAB308"; style.border-radius: 8}
  page: {shape: page; style.fill: "#F8FAFC"; style.stroke: "#94A3B8"}
}

input: User Message {class: page}

ingestion: Ingestion {
  class: blue
  guard: "Truncation Guard\n≤15 facts" {style.fill: "#EFF6FF"; style.stroke: "#93C5FD"; style.border-radius: 6}
  extract: "LLM Extraction\nmemories · entities\nrelations · context" {style.fill: "#EFF6FF"; style.stroke: "#93C5FD"; style.border-radius: 6}
  embed: "Batch Embedding\n768-dim vectors" {style.fill: "#EFF6FF"; style.stroke: "#93C5FD"; style.border-radius: 6}

  guard -> extract -> embed
}

dedup: Deduplication {
  class: orange
  phase1: "Phase 1\nPersonal Search" {style.fill: "#FFF7ED"; style.stroke: "#FDBA74"; style.border-radius: 6}
  decision: "LLM Decision\nretry + validation" {style.fill: "#FFF7ED"; style.stroke: "#FDBA74"; style.border-radius: 6}
  dup_check: "Exact dup?" {shape: diamond; style.fill: "#FEF3C7"; style.stroke: "#F59E0B"}

  phase1 -> decision -> dup_check
}

storage: Persistence {
  class: green
  store: "Store Memory\n+ Embedding\n+ User Link\n+ History Event" {style.fill: "#F0FDF4"; style.stroke: "#86EFAC"; style.border-radius: 6}
  db: "HelixDB v2.3.3\n117 queries" {shape: cylinder; style.fill: "#166534"; style.font-color: white}

  store -> db
}

hive: Hive Layer {
  class: purple
  cache: "Moka Cache\nSHA-256 · TTL 60s" {style.fill: "#FAF5FF"; style.stroke: "#C084FC"; style.border-radius: 6}
  phase2: "Phase 2\nGlobal Search" {style.fill: "#FAF5FF"; style.stroke: "#C084FC"; style.border-radius: 6}
  cross: "Cross-User Decision\nLink · Contradict" {style.fill: "#FAF5FF"; style.stroke: "#C084FC"; style.border-radius: 6}

  cache -> phase2: miss
  phase2 -> cross
}

enrichment: Enrichment {
  class: rose
  entities: "Entity Linking\n+ Relations" {style.fill: "#FFF1F2"; style.stroke: "#FDA4AF"; style.border-radius: 6}
  concepts: "Ontology\n7 types" {style.fill: "#FFF1F2"; style.stroke: "#FDA4AF"; style.border-radius: 6}
  reasoning: "Reasoning\nIMPLIES · BECAUSE\nCONTRADICTS" {style.fill: "#FFF1F2"; style.stroke: "#FDA4AF"; style.border-radius: 6}
  context: "Context\nVALID_IN" {style.fill: "#FFF1F2"; style.stroke: "#FDA4AF"; style.border-radius: 6}
  agent: "Agent\nTracking" {style.fill: "#FFF1F2"; style.stroke: "#FDA4AF"; style.border-radius: 6}
  history: "History\nEvents" {style.fill: "#FFF1F2"; style.stroke: "#FDA4AF"; style.border-radius: 6}
}

events: EventBus {
  class: amber
  style.double-border: true
  types: "memory.added · updated\nsuperseded · deduplicated\nsearch.executed\nllm.decision.made" {style.fill: "#FEFCE8"; style.stroke: "#FDE047"; style.border-radius: 6}
}

result: AddMemoryResult {class: page}

# Main pipeline
input -> ingestion.guard
ingestion.embed -> dedup.phase1: vectors
dedup.decision -> storage.store: "ADD / UPDATE" {style.stroke: "#22C55E"}
dedup.decision -> result: NOOP {style.stroke-dash: 3; style.stroke: "#94A3B8"}
dedup.dup_check -> hive.cache: "no dup → Phase 2" {style.stroke: "#A855F7"}
dedup.dup_check -> result: "dup → skip" {style.stroke-dash: 3; style.stroke: "#94A3B8"}

# Hive back to DB
hive.cross -> storage.db: "link / contradict" {style.stroke: "#A855F7"}

# Storage -> Enrichment -> DB (single clean flow)
storage.store -> enrichment: memory_id {style.stroke: "#F43F5E"}
enrichment -> storage.db: "write edges" {style.stroke: "#F43F5E"}

# Events (dashed, non-primary)
storage.store -> events: emit {style.stroke-dash: 3; style.stroke: "#EAB308"}

# Final
storage.db -> result
