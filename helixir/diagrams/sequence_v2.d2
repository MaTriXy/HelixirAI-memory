shape: sequence_diagram

cursor: Cursor IDE {
  style.fill: "#DBEAFE"
  style.stroke: "#3B82F6"
}
mcp: MCP Server {
  style.fill: "#DBEAFE"
  style.stroke: "#3B82F6"
}
client: HelixirClient {
  style.fill: "#FFF7ED"
  style.stroke: "#F97316"
}
tooling: ToolingManager {
  style.fill: "#DCFCE7"
  style.stroke: "#22C55E"
}
search: SearchEngine {
  style.fill: "#F3E8FF"
  style.stroke: "#A855F7"
}
extractor: LLM Extractor {
  style.fill: "#FFE4E6"
  style.stroke: "#F43F5E"
}
decision: LLM Decision {
  style.fill: "#FFE4E6"
  style.stroke: "#F43F5E"
}
embed: Embeddings {
  style.fill: "#FFE4E6"
  style.stroke: "#F43F5E"
}
db: HelixDB {
  style.fill: "#F1F5F9"
  style.stroke: "#64748B"
}
events: EventBus {
  style.fill: "#FEF9C3"
  style.stroke: "#EAB308"
}
cache: Moka Cache {
  style.fill: "#F3E8FF"
  style.stroke: "#A855F7"
}

add: "add_memory" {
  cursor -> mcp: "add_memory(message, user_id)"
  mcp -> client: "add()"
  client -> tooling: "add_memory()"

  tooling -> extractor: "extract(entities + relations)"
  extractor -> tooling: "memories[] · entities[] · relations[]"

  tooling -> embed: "generate_batch(texts[])"
  embed -> tooling: "vectors[]"

  tooling -> search: "search(vector, personal)"
  search -> db: "smartVectorSearch"
  db -> search: "similar[]"
  search -> tooling: results

  tooling -> decision: "decide(new, similar)"
  decision -> tooling: "ADD (confidence 85)"
  tooling -> events: "llm.decision.made" {style.stroke: "#EAB308"; style.stroke-dash: 3}

  tooling -> db: "addMemory + Embedding + UserLink + History"
  db -> tooling: memory_id
  tooling -> events: "memory.added" {style.stroke: "#EAB308"; style.stroke-dash: 3}

  tooling -> cache: "lookup(SHA-256)"
  cache -> tooling: miss
  tooling -> search: "search(vector, collective)"
  search -> db: globalVectorSearch
  db -> search: "cross-user matches"
  search -> tooling: results
  tooling -> cache: "insert(results)"

  tooling -> decision: "decide(cross-user)"
  decision -> tooling: LINK_EXISTING
  tooling -> db: "linkUser + updateUserCount"

  tooling -> db: "entities · concepts · reasoning edges"

  tooling -> client: AddMemoryResult
  client -> mcp: result
  mcp -> cursor: JSON
}

search_flow: "search_memory" {
  cursor -> mcp: "search_memory(query, collective)"
  mcp -> client: "search()"
  client -> tooling: "search_memory()"

  tooling -> embed: "generate(query)"
  embed -> tooling: vector

  tooling -> search: "search(vector, collective)"
  search -> cache: lookup
  cache -> search: miss
  search -> db: smartVectorSearch
  db -> search: memories
  search -> db: getMemoryUsers
  db -> search: user_count
  search -> db: getMemoryContradictions
  db -> search: controversies
  search -> cache: insert
  search -> tooling: "results + metadata"

  tooling -> events: "search.executed" {style.stroke: "#EAB308"; style.stroke-dash: 3}
  tooling -> client: "SearchResult[]"
  client -> mcp: results
  mcp -> cursor: "JSON [{id, content, score, user_count}]"
}
